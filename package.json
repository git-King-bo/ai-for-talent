{
  "name": "talentai",
  "version": "0.1.0",
  "private": true,
  "description": "AI for Talent desktop application built with Vue 3, Vite, and Tauri.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:starter": "VITE_SHELL_APP_ID=starter VITE_APP_NAME='Starter Shell' VITE_APP_TITLE='Starter Shell' VITE_APP_TITLE_SUFFIX='Starter Shell' VITE_SHELL_BACKGROUND=none vite",
    "dev:test": "vite --mode test",
    "dev:pre": "vite --mode pre",
    "dev:prod": "vite --mode production",
    "dev:desktop": "node scripts/run-vite-env.mjs dev",
    "build": "vite build",
    "build:starter": "VITE_SHELL_APP_ID=starter VITE_APP_NAME='Starter Shell' VITE_APP_TITLE='Starter Shell' VITE_APP_TITLE_SUFFIX='Starter Shell' VITE_SHELL_BACKGROUND=none vite build",
    "build:test": "vite build --mode test",
    "build:pre": "vite build --mode pre",
    "build:prod": "vite build --mode production",
    "build:desktop": "node scripts/run-vite-env.mjs build",
    "preview": "vite preview",
    "format": "prettier --write --experimental-cli src/",
    "shell:check": "node scripts/validate-shell.mjs",
    "shell:new": "node scripts/scaffold-shell-app.mjs",
    "tauri": "tauri",
    "desktop:icon": "tauri icon src-tauri/icons/app-icon.svg",
    "tauri:shell": "node scripts/run-tauri.mjs",
    "desktop:dev": "node scripts/run-tauri.mjs dev",
    "desktop:starter": "VITE_SHELL_APP_ID=starter VITE_APP_NAME='Starter Shell' VITE_APP_TITLE='Starter Shell' VITE_APP_TITLE_SUFFIX='Starter Shell' VITE_SHELL_BACKGROUND=none node scripts/run-tauri.mjs dev",
    "desktop:test": "TAURI_APP_ENV=test node scripts/run-tauri.mjs dev",
    "desktop:pre": "TAURI_APP_ENV=pre node scripts/run-tauri.mjs dev",
    "desktop:prod": "TAURI_APP_ENV=prod node scripts/run-tauri.mjs dev",
    "desktop:build:debug": "node scripts/run-tauri.mjs build --debug --bundles app",
    "desktop:build": "node scripts/run-tauri.mjs build --bundles app",
    "desktop:build:starter": "VITE_SHELL_APP_ID=starter VITE_APP_NAME='Starter Shell' VITE_APP_TITLE='Starter Shell' VITE_APP_TITLE_SUFFIX='Starter Shell' VITE_SHELL_BACKGROUND=none node scripts/run-tauri.mjs build --bundles app",
    "desktop:build:test": "TAURI_APP_ENV=test node scripts/run-tauri.mjs build --bundles app",
    "desktop:build:pre": "TAURI_APP_ENV=pre node scripts/run-tauri.mjs build --bundles app",
    "desktop:build:prod": "TAURI_APP_ENV=prod node scripts/run-tauri.mjs build --bundles app",
    "desktop:build:devtools": "node scripts/run-tauri.mjs build --features release-devtools --bundles app",
    "desktop:package:dmg": "bash scripts/package-macos-dmg.sh",
    "desktop:package:dmg:refresh-bg": "DMG_FORCE_REBUILD_BACKGROUND=1 bash scripts/package-macos-dmg.sh",
    "desktop:package": "npm run desktop:build && npm run desktop:package:dmg",
    "desktop:package:win": "node scripts/run-tauri.mjs build --bundles nsis,msi",
    "desktop:package:win:nsis": "node scripts/run-tauri.mjs build --bundles nsis",
    "desktop:package:win:msi": "node scripts/run-tauri.mjs build --bundles msi"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.3",
    "@tauri-apps/api": "^2.10.1",
    "echarts": "^6.0.0",
    "pinia": "^3.0.4",
    "sass": "^1.99.0",
    "tailwindcss": "^4.2.3",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "appdmg": "^0.6.6",
    "pngjs": "^7.0.0",
    "prettier": "3.8.3",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
